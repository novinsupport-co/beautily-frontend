{
  "compilerOptions": {
    // 👇 رفع خطاهای import.meta و module resolution
    "module": "ES2022",
    "moduleResolution": "bundler",
    "target": "ES2022",

    "strict": true,
    "jsx": "preserve",
    "allowJs": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "forceConsistentCasingInFileNames": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },

    "types": ["vite/client", "node"]
  },

  // 👇 شمول فایل پیکربندی Vite برای اعمال تنظیمات
  "include": [
    "src/**/*.ts",
    "src/**/*.d.ts",
    "src/**/*.vue",
    "vite.config.ts",
    // 👇 اطمینان از شمول فایل پیکربندی ESLint
    "eslint.config.js"
  ],
  "references": []
}